rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Feedback tickets - public collection
    match /feedback/tickets/{ticketId} {
      // Anyone can read any ticket (for transparency)
      allow read: if true;
      
      // Anyone can create tickets
      allow create: if true;
      
      // Only allow updates/deletes to tickets created by the same user
      allow update: if request.auth == null || 
                     resource.data.createdBy == request.resource.data.createdBy;
      allow delete: if request.auth == null && 
                     resource.data.createdBy == request.resource.data.createdBy;
    }
    
    // Optional: Admin collection for future use
    match /admins/{adminId} {
      allow read: if false;
      allow write: if false;
    }
    
    // Test collection for debugging
    match /test/{document=**} {
      allow read, write: if true;
    }
  }
}