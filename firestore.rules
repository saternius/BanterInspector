rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Feedback collection rules with subcollections
    match /feedback/{userId}/tickets/{ticketId} {
      // Anyone can read any ticket (for transparency)
      allow read: if true;
      
      // Anyone can create feedback under any userId (since userId acts as the password)
      allow create: if true;
      
      // Only allow updates/deletes to documents created by the same user
      // The userId in the path and createdBy field must match
      allow update, delete: if userId == resource.data.createdBy;
    }
    
    // Allow listing feedback directories to get all tickets
    match /feedback/{userId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Allow listing the root feedback collection
    match /feedback {
      allow read: if true;
      allow write: if false;
    }
    
    // Optional: Admin collection for future use
    match /admins/{adminId} {
      allow read: if false;
      allow write: if false;
    }
    
    // Test collection for debugging
    match /test/{document=**} {
      allow read, write: if true;
    }
  }
}